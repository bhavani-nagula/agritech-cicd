#cloud-config
package_update: true
package_upgrade: true

packages:
  - nginx
  - openjdk-17-jdk
  - curl
  - unzip

write_files:
  - path: /var/www/agritech/static.html
    permissions: "0644"
    owner: root:root
    content: |
            <!DOCTYPE html>
    <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>AgriTech Marketplace</title>

      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />

      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      />

      <link rel="stylesheet" href="css/style.css" />
    </head>

    <body data-page="home">
      <header class="topbar">
        <a class="brand" href="static.html">
          <span class="brand-mark">
            <i class="fa-solid fa-seedling"></i>
          </span>
          <span>
            <strong>AgriTech Marketplace</strong>
            <small>AI crop-input recommendations</small>
          </span>
        </a>

        <nav class="nav">
          <a href="static.html" class="active">
            <i class="fa-solid fa-house"></i> Home
          </a>
          <a href="pages/login.html">
            <i class="fa-solid fa-right-to-bracket"></i> Login
          </a>
          <a href="pages/register.html">
            <i class="fa-solid fa-user-plus"></i> Register
          </a>
          <a href="pages/cart.html" class="cart-link">
            <i class="fa-solid fa-basket-shopping"></i>
            Cart
            <span id="cartCount">0</span>
          </a>
        </nav>
      </header>

      <main>
        <section class="hero container">
          <div class="hero-copy">
            <span class="pill">
              <i class="fa-solid fa-robot"></i>
              AI-Powered AgriTech Store
            </span>

            <h1>Right product for the right crop stage.</h1>

            <p>
              Discover compost, neem spray, vermicompost, bio-fertilizers and
              crop-specific care kits recommended for farmers and agri-consultants.
            </p>

            <div class="hero-actions">
              <a href="#catalog" class="btn btn-primary">
                Explore products
                <i class="fa-solid fa-arrow-right"></i>
              </a>
              <a href="pages/cart.html" class="btn btn-secondary">
                <i class="fa-solid fa-basket-shopping"></i>
                View cart
              </a>
            </div>

            <div class="trust-row">
              <span><i class="fa-solid fa-circle-check"></i> Organic inputs</span>
              <span><i class="fa-solid fa-truck-fast"></i> Farmer-ready demo</span>
              <span><i class="fa-solid fa-shield-heart"></i> Crop-safe choices</span>
            </div>
          </div>

          <div class="hero-visual">
            <div class="hero-image-card">
              <img
                src="assets/images/hero-banner.jpg"
                alt="Farmer checking crop recommendations"
                onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1500937386664-56d1dfef3854?auto=format&fit=crop&w=1000&q=80';"
              />

              <div class="floating-card">
                <span class="floating-icon">
                  <i class="fa-solid fa-sparkles"></i>
                </span>
                <div>
                  <strong>Smart crop match</strong>
                  <small>Tomato flowering support found</small>
                </div>
              </div>
            </div>

            <div class="crop-mini-grid">
              <article>
                <i class="fa-solid fa-apple-whole"></i>
                <span>Tomato</span>
              </article>
              <article>
                <i class="fa-solid fa-carrot"></i>
                <span>Potato</span>
              </article>
              <article>
                <i class="fa-solid fa-wheat-awn"></i>
                <span>Wheat</span>
              </article>
              <article>
                <i class="fa-solid fa-tree"></i>
                <span>Orchard</span>
              </article>
            </div>
          </div>
        </section>

        <section class="stats container">
          <article>
            <i class="fa-solid fa-layer-group"></i>
            <strong>6+</strong>
            <span>Crop categories</span>
          </article>
          <article>
            <i class="fa-solid fa-leaf"></i>
            <strong>100%</strong>
            <span>Organic-focused demo</span>
          </article>
          <article>
            <i class="fa-solid fa-bolt"></i>
            <strong>Fast</strong>
            <span>Static frontend</span>
          </article>
          <article>
            <i class="fa-solid fa-cart-shopping"></i>
            <strong>Local</strong>
            <span>Cart storage</span>
          </article>
        </section>

        <section class="catalog container" id="catalog">
          <div class="section-head">
            <div>
              <span class="pill soft">
                <i class="fa-solid fa-store"></i>
                Product Catalog
              </span>
              <h2>Crop-based recommendations</h2>
              <p>Search and filter products by crop, ingredient, category or stage.</p>
            </div>

            <div class="searchbox">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input
                id="searchInput"
                type="search"
                placeholder="Search tomato, neem, compost..."
              />
            </div>
          </div>

          <div class="filterbar" id="filterBar">
            <button class="chip active" data-filter="all">
              <i class="fa-solid fa-border-all"></i> All
            </button>
            <button class="chip" data-filter="tomato">
              <i class="fa-solid fa-apple-whole"></i> Tomato
            </button>
            <button class="chip" data-filter="potato">
              <i class="fa-solid fa-carrot"></i> Potato
            </button>
            <button class="chip" data-filter="grapes">
              <i class="fa-solid fa-shield-halved"></i> Grapes
            </button>
            <button class="chip" data-filter="wheat">
              <i class="fa-solid fa-wheat-awn"></i> Wheat
            </button>
            <button class="chip" data-filter="leafy">
              <i class="fa-solid fa-leaf"></i> Leafy greens
            </button>
            <button class="chip" data-filter="orchard">
              <i class="fa-solid fa-tree"></i> Orchards
            </button>
          </div>

          <div class="grid" id="productGrid"></div>
        </section>

        <section class="highlight container">
          <div class="section-head simple">
            <div>
              <span class="pill soft">
                <i class="fa-solid fa-star"></i>
                Why it looks premium
              </span>
              <h2>Designed for a clean marketplace experience</h2>
            </div>
          </div>

          <div class="highlight-grid">
            <article>
              <i class="fa-solid fa-image"></i>
              <h3>Image-led cards</h3>
              <p>Each product is visually clear and easy to scan quickly.</p>
            </article>

            <article>
              <i class="fa-solid fa-window-restore"></i>
              <h3>Modal preview</h3>
              <p>Product details open beautifully without leaving the page.</p>
            </article>

            <article>
              <i class="fa-solid fa-database"></i>
              <h3>Local cart</h3>
              <p>The cart uses browser storage, so the demo works smoothly.</p>
            </article>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div class="container footer-inner">
          <p>
            <i class="fa-solid fa-seedling"></i>
            AgriTech Marketplace — Premium static frontend with image and icon support.
          </p>
        </div>
      </footer>

      <div class="modal hidden" id="productModal" aria-hidden="true">
        <div class="modal-card">
          <button class="modal-close" id="closeModal" aria-label="Close modal">
            <i class="fa-solid fa-xmark"></i>
          </button>
          <div id="modalBody"></div>
        </div>
      </div>

      <script src="js/data.js"></script>
      <script src="js/app.js"></script>
    </body>
    </html>

  - path: /var/www/agritech/css/style.css
    permissions: "0644"
    owner: root:root
    content: |
            :root {
      --bg: #f4faef;
      --card: rgba(255, 255, 255, 0.92);
      --text: #13231b;
      --muted: #66756d;
      --primary: #219653;
      --primary-dark: #116b37;
      --primary-soft: #e8f8ee;
      --accent: #f4b740;
      --danger: #e5484d;
      --border: rgba(28, 84, 54, 0.14);
      --shadow: 0 24px 70px rgba(21, 67, 42, 0.14);
      --shadow-soft: 0 14px 35px rgba(21, 67, 42, 0.1);
      --radius: 26px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: "Inter", Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(110, 231, 183, 0.28), transparent 32rem),
        radial-gradient(circle at top right, rgba(244, 183, 64, 0.18), transparent 28rem),
        linear-gradient(180deg, #fbfff8 0%, #eef8eb 100%);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(33, 150, 83, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(33, 150, 83, 0.05) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: linear-gradient(to bottom, black, transparent 75%);
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input {
      font: inherit;
    }

    .container {
      width: min(1180px, calc(100% - 36px));
      margin-inline: auto;
    }

    /* Navbar */

    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      padding: 16px max(18px, calc((100% - 1180px) / 2));
      background: rgba(251, 255, 248, 0.8);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-mark {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      color: white;
      background:
        linear-gradient(135deg, var(--primary), #5ecf84);
      box-shadow: 0 12px 28px rgba(33, 150, 83, 0.32);
    }

    .brand strong {
      display: block;
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .brand small {
      display: block;
      margin-top: 2px;
      color: var(--muted);
      font-size: 0.78rem;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .nav a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 13px;
      border-radius: 999px;
      color: var(--muted);
      font-weight: 700;
      transition: 0.25s ease;
    }

    .nav a:hover,
    .nav a.active {
      color: var(--primary-dark);
      background: var(--primary-soft);
    }

    .cart-link span {
      min-width: 23px;
      height: 23px;
      padding: 0 7px;
      display: inline-grid;
      place-items: center;
      border-radius: 999px;
      color: white;
      background: var(--primary);
      font-size: 0.78rem;
    }

    /* Hero */

    .hero {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 28px;
      padding: 48px 0 24px;
      align-items: center;
    }

    .hero-copy,
    .hero-image-card,
    .stats article,
    .card,
    .highlight article,
    .form-card,
    .checkout-card,
    .modal-card {
      background: var(--card);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      border-radius: var(--radius);
    }

    .hero-copy {
      position: relative;
      overflow: hidden;
      padding: clamp(28px, 5vw, 54px);
    }

    .hero-copy::after {
      content: "";
      position: absolute;
      width: 240px;
      height: 240px;
      right: -100px;
      bottom: -120px;
      border-radius: 50%;
      background: rgba(33, 150, 83, 0.12);
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 8px 12px;
      border-radius: 999px;
      color: var(--primary-dark);
      background: var(--primary-soft);
      font-size: 0.82rem;
      font-weight: 900;
    }

    .pill.soft {
      background: rgba(255, 255, 255, 0.7);
      border: 1px solid var(--border);
    }

    .hero h1,
    .section-head h2,
    .auth-title {
      margin: 18px 0 14px;
      font-size: clamp(2.45rem, 6vw, 5.3rem);
      line-height: 0.95;
      letter-spacing: -0.075em;
    }

    .section-head h2 {
      font-size: clamp(2rem, 4vw, 3.5rem);
    }

    .hero p,
    .section-head p,
    .card p,
    .highlight p,
    .form-card p,
    .checkout-card p {
      color: var(--muted);
      line-height: 1.75;
    }

    .hero-copy > p {
      max-width: 650px;
      font-size: 1.06rem;
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .btn,
    .card-btn,
    .modal-action,
    .form-btn,
    .qty-btn,
    .icon-btn {
      border: 0;
      cursor: pointer;
      border-radius: 999px;
      font-weight: 900;
      transition: 0.25s ease;
    }

    .btn,
    .form-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 19px;
    }

    .btn:hover,
    .card-btn:hover,
    .modal-action:hover,
    .form-btn:hover,
    .qty-btn:hover,
    .icon-btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary,
    .form-btn.primary,
    .card-btn.primary,
    .modal-action.primary {
      color: white;
      background: linear-gradient(135deg, var(--primary), #44c96f);
      box-shadow: 0 14px 30px rgba(33, 150, 83, 0.28);
    }

    .btn-secondary,
    .form-btn.secondary,
    .card-btn.secondary,
    .modal-action.secondary {
      color: var(--primary-dark);
      background: var(--primary-soft);
    }

    .trust-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 28px;
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 700;
    }

    .trust-row i {
      color: var(--primary);
    }

    /* Hero visual */

    .hero-visual {
      display: grid;
      gap: 16px;
    }

    .hero-image-card {
      position: relative;
      padding: 14px;
    }

    .hero-image-card img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      border-radius: 22px;
    }

    .floating-card {
      position: absolute;
      left: 30px;
      right: 30px;
      bottom: 30px;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.86);
      backdrop-filter: blur(16px);
      box-shadow: var(--shadow-soft);
    }

    .floating-card small {
      display: block;
      color: var(--muted);
      margin-top: 3px;
    }

    .floating-icon {
      width: 44px;
      height: 44px;
      display: grid;
      place-items: center;
      flex: 0 0 auto;
      border-radius: 16px;
      color: white;
      background: linear-gradient(135deg, var(--accent), #ffda75);
    }

    .crop-mini-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }

    .crop-mini-grid article {
      padding: 16px 10px;
      text-align: center;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-soft);
    }

    .crop-mini-grid i {
      display: block;
      margin-bottom: 8px;
      color: var(--primary);
      font-size: 1.25rem;
    }

    .crop-mini-grid span {
      font-size: 0.82rem;
      font-weight: 900;
    }

    /* Stats */

    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      padding: 18px 0 42px;
    }

    .stats article {
      padding: 24px;
    }

    .stats i {
      color: var(--primary);
      font-size: 1.4rem;
    }

    .stats strong {
      display: block;
      margin-top: 12px;
      font-size: 2rem;
      letter-spacing: -0.06em;
    }

    .stats span {
      color: var(--muted);
      font-weight: 700;
    }

    /* Catalog */

    .catalog {
      padding: 20px 0 48px;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 22px;
      margin-bottom: 18px;
    }

    .section-head.simple {
      align-items: start;
    }

    .searchbox {
      position: relative;
      width: min(390px, 100%);
    }

    .searchbox i {
      position: absolute;
      left: 17px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--primary);
    }

    .searchbox input {
      width: 100%;
      padding: 15px 16px 15px 45px;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.86);
      outline: none;
      box-shadow: var(--shadow-soft);
    }

    .searchbox input:focus,
    .input-wrap input:focus {
      border-color: rgba(33, 150, 83, 0.55);
      box-shadow: 0 0 0 5px rgba(33, 150, 83, 0.12);
    }

    .filterbar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 18px 0 22px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--border);
      padding: 11px 14px;
      border-radius: 999px;
      cursor: pointer;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.78);
      font-weight: 900;
      transition: 0.25s ease;
    }

    .chip:hover,
    .chip.active {
      color: white;
      border-color: transparent;
      background: linear-gradient(135deg, var(--primary), #44c96f);
      box-shadow: 0 12px 25px rgba(33, 150, 83, 0.22);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    /* Product card */

    .card {
      position: relative;
      overflow: hidden;
      padding: 14px;
      transition: 0.28s ease;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 30px 80px rgba(21, 67, 42, 0.18);
    }

    .card-image-wrap {
      position: relative;
      overflow: hidden;
      border-radius: 22px;
    }

    .card-image {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      transition: 0.4s ease;
    }

    .card:hover .card-image {
      transform: scale(1.045);
    }

    .card-icon {
      position: absolute;
      left: 14px;
      top: 14px;
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      border-radius: 16px;
      color: white;
      background: rgba(33, 150, 83, 0.94);
      backdrop-filter: blur(12px);
    }

    .badge {
      position: absolute;
      right: 14px;
      top: 14px;
      padding: 8px 11px;
      border-radius: 999px;
      color: var(--text);
      background: rgba(255, 255, 255, 0.9);
      font-size: 0.75rem;
      font-weight: 900;
    }

    .card-body {
      padding: 18px 5px 4px;
    }

    .card h3 {
      margin: 10px 0 8px;
      font-size: 1.18rem;
      letter-spacing: -0.03em;
    }

    .card-meta {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 9px;
      border-radius: 999px;
      color: var(--primary-dark);
      background: var(--primary-soft);
      font-size: 0.76rem;
      font-weight: 900;
    }

    .card-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      margin-top: 16px;
    }

    .price {
      font-size: 1.45rem;
      font-weight: 900;
      letter-spacing: -0.05em;
    }

    .rating {
      color: #f6a800;
      font-size: 0.85rem;
      font-weight: 900;
    }

    .card-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 14px;
    }

    .card-btn,
    .modal-action {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      padding: 12px 13px;
    }

    /* Highlight */

    .highlight {
      padding: 18px 0 50px;
    }

    .highlight-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .highlight article {
      padding: 28px;
    }

    .highlight article i {
      width: 52px;
      height: 52px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      color: white;
      background: linear-gradient(135deg, var(--primary), #44c96f);
    }

    .highlight h3 {
      margin-bottom: 8px;
    }

    /* Modal */

    .modal {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: grid;
      place-items: center;
      padding: 20px;
      background: rgba(8, 20, 14, 0.62);
      backdrop-filter: blur(10px);
    }

    .modal.hidden {
      display: none;
    }

    .modal-card {
      position: relative;
      width: min(860px, 100%);
      padding: 18px;
      animation: pop 0.2s ease;
    }

    @keyframes pop {
      from {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }
    }

    .modal-close {
      position: absolute;
      top: 16px;
      right: 16px;
      z-index: 3;
      width: 42px;
      height: 42px;
      border: 0;
      border-radius: 999px;
      cursor: pointer;
      color: var(--text);
      background: rgba(255, 255, 255, 0.88);
    }

    .modal-grid {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: 22px;
      align-items: center;
    }

    .modal-img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      border-radius: 24px;
    }

    .modal-info {
      padding: 16px;
    }

    .modal-info h2 {
      font-size: clamp(1.8rem, 4vw, 3rem);
      line-height: 1;
      letter-spacing: -0.06em;
      margin: 14px 0;
    }

    .detail-list {
      display: grid;
      gap: 10px;
      margin: 16px 0;
    }

    .detail-list p {
      margin: 0;
      color: var(--muted);
    }

    .detail-list strong {
      color: var(--text);
    }

    /* Cart */

    .cart-page {
      padding: 42px 0 70px;
    }

    .cart-layout {
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 22px;
      align-items: start;
    }

    .cart-list {
      display: grid;
      gap: 14px;
    }

    .cart-row {
      display: grid;
      grid-template-columns: 86px 1fr auto;
      gap: 16px;
      align-items: center;
      padding: 14px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid var(--border);
      box-shadow: var(--shadow-soft);
    }

    .cart-img {
      width: 86px;
      height: 86px;
      border-radius: 20px;
      object-fit: cover;
    }

    .cart-row h3 {
      margin: 0 0 6px;
    }

    .cart-row p {
      margin: 0;
      color: var(--muted);
    }

    .cart-actions {
      display: grid;
      justify-items: end;
      gap: 12px;
    }

    .qty-stepper {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px;
      border-radius: 999px;
      background: var(--primary-soft);
    }

    .qty-btn,
    .icon-btn {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      color: var(--primary-dark);
      background: white;
    }

    .icon-btn.danger {
      color: white;
      background: var(--danger);
    }

    .checkout-card {
      position: sticky;
      top: 96px;
      padding: 24px;
    }

    .checkout-line {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
    }

    .checkout-line.total {
      border-bottom: 0;
      font-size: 1.35rem;
      font-weight: 900;
    }

    .empty-state {
      padding: 34px;
      text-align: center;
    }

    .empty-state i {
      font-size: 2.4rem;
      color: var(--primary);
    }

    /* Auth pages */

    .auth-body {
      min-height: 100vh;
    }

    .auth-shell {
      min-height: calc(100vh - 82px);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      align-items: center;
      padding: 44px 0;
    }

    .auth-panel {
      padding: clamp(28px, 5vw, 48px);
      border-radius: var(--radius);
      color: white;
      background:
        linear-gradient(135deg, rgba(17, 107, 55, 0.96), rgba(68, 201, 111, 0.88)),
        url("../assets/images/hero-banner.jpg") center / cover;
      box-shadow: var(--shadow);
    }

    .auth-panel h1 {
      font-size: clamp(2.4rem, 5vw, 4.6rem);
      line-height: 0.95;
      letter-spacing: -0.075em;
    }

    .auth-panel p {
      line-height: 1.8;
      opacity: 0.9;
    }

    .auth-benefits {
      display: grid;
      gap: 13px;
      margin-top: 28px;
    }

    .auth-benefits span {
      display: flex;
      gap: 10px;
      align-items: center;
      font-weight: 800;
    }

    .form-card {
      padding: clamp(24px, 4vw, 38px);
    }

    .form-card h1 {
      margin: 0 0 8px;
      font-size: clamp(2rem, 4vw, 3rem);
      letter-spacing: -0.065em;
    }

    .form-grid {
      display: grid;
      gap: 14px;
      margin-top: 22px;
    }

    .form-grid label {
      font-weight: 900;
      font-size: 0.9rem;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap i {
      position: absolute;
      top: 50%;
      left: 16px;
      transform: translateY(-50%);
      color: var(--primary);
    }

    .input-wrap input {
      width: 100%;
      padding: 15px 16px 15px 45px;
      border: 1px solid var(--border);
      border-radius: 17px;
      outline: none;
      background: white;
    }

    /* Footer and toast */

    .footer {
      padding: 28px 0 36px;
      color: var(--muted);
    }

    .footer-inner {
      display: flex;
      justify-content: center;
      text-align: center;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 24px;
      z-index: 80;
      transform: translate(-50%, 20px);
      opacity: 0;
      pointer-events: none;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px 18px;
      border-radius: 999px;
      color: white;
      background: #13231b;
      box-shadow: var(--shadow);
      transition: 0.25s ease;
      font-weight: 800;
    }

    .toast.show {
      opacity: 1;
      transform: translate(-50%, 0);
    }

    /* Responsive */

    @media (max-width: 980px) {
      .hero,
      .auth-shell,
      .cart-layout,
      .modal-grid {
        grid-template-columns: 1fr;
      }

      .grid,
      .stats,
      .highlight-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .section-head {
        align-items: start;
        flex-direction: column;
      }

      .searchbox {
        width: 100%;
      }

      .checkout-card {
        position: static;
      }
    }

    @media (max-width: 680px) {
      .topbar {
        position: relative;
        align-items: flex-start;
        flex-direction: column;
      }

      .nav {
        width: 100%;
      }

      .nav a {
        flex: 1;
        justify-content: center;
      }

      .hero h1 {
        font-size: 3rem;
      }

      .grid,
      .stats,
      .highlight-grid,
      .crop-mini-grid {
        grid-template-columns: 1fr;
      }

      .card-actions {
        grid-template-columns: 1fr;
      }

      .cart-row {
        grid-template-columns: 1fr;
      }

      .cart-img {
        width: 100%;
        height: 180px;
      }

      .cart-actions {
        justify-items: start;
      }
    }

  - path: /var/www/agritech/js/app.js
    permissions: "0644"
    owner: root:root
    content: |
            const STORAGE_KEY = "agritech-premium-cart-v1";

    const byId = (id) => document.getElementById(id);

    const money = (value) =>
      new Intl.NumberFormat("en-IN", {
        style: "currency",
        currency: "INR",
        maximumFractionDigits: 0
      }).format(value);

    const escapeHtml = (value = "") =>
      String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    function assetUrl(path = "") {
      if (!path) return "";
      if (/^(https?:|data:|\/)/i.test(path)) return path;

      const page = document.body.dataset.page || "home";
      return page === "home" ? path : `../$${path}`;
    }

    function loadCart() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
      } catch {
        return [];
      }
    }

    const state = {
      filter: "all",
      search: "",
      cart: loadCart()
    };

    function getProducts() {
      return window.PRODUCTS || [];
    }

    function saveCart() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state.cart));
      updateCartCount();
    }

    function updateCartCount() {
      const count = state.cart.reduce((sum, item) => sum + item.qty, 0);
      const el = byId("cartCount");

      if (el) {
        el.textContent = String(count);
      }
    }

    function showToast(message) {
      let toast = byId("toast");

      if (!toast) {
        toast = document.createElement("div");
        toast.id = "toast";
        toast.className = "toast";
        document.body.appendChild(toast);
      }

      toast.innerHTML = `
        <i class="fa-solid fa-circle-check"></i>
        <span>$${escapeHtml(message)}</span>
      `;

      toast.classList.add("show");

      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => {
        toast.classList.remove("show");
      }, 1900);
    }

    function renderProducts() {
      const grid = byId("productGrid");
      if (!grid) return;

      const query = state.search.trim().toLowerCase();

      const products = getProducts().filter((p) => {
        const matchesFilter = state.filter === "all" || p.crop === state.filter;

        const matchesSearch =
          !query ||
          p.name.toLowerCase().includes(query) ||
          p.crop.toLowerCase().includes(query) ||
          p.category.toLowerCase().includes(query) ||
          p.stage.toLowerCase().includes(query) ||
          p.description.toLowerCase().includes(query) ||
          p.ingredients.join(" ").toLowerCase().includes(query);

        return matchesFilter && matchesSearch;
      });

      if (!products.length) {
        grid.innerHTML = `
          <article class="card empty-state">
            <i class="fa-solid fa-magnifying-glass"></i>
            <h3>No products found</h3>
            <p>Try another crop, ingredient or product name.</p>
          </article>
        `;
        return;
      }

      grid.innerHTML = products
        .map(
          (p) => `
            <article class="card">
              <div class="card-image-wrap">
                <img
                  class="card-image"
                  src="$${escapeHtml(assetUrl(p.image))}"
                  alt="$${escapeHtml(p.name)}"
                  loading="lazy"
                  onerror="this.onerror=null;this.src='$${escapeHtml(p.fallback)}';"
                />

                <span class="card-icon">
                  <i class="$${escapeHtml(p.icon)}"></i>
                </span>

                <span class="badge">
                  <i class="fa-solid fa-award"></i>
                  $${escapeHtml(p.badge)}
                </span>
              </div>

              <div class="card-body">
                <div class="card-meta">
                  <span class="tag">
                    <i class="fa-solid fa-seedling"></i>
                    $${escapeHtml(p.crop)}
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-calendar-check"></i>
                    $${escapeHtml(p.stage)}
                  </span>
                </div>

                <h3>$${escapeHtml(p.name)}</h3>
                <p>$${escapeHtml(p.description)}</p>

                <div class="card-foot">
                  <div>
                    <div class="price">$${money(p.price)}</div>
                    <div class="rating">
                      <i class="fa-solid fa-star"></i>
                      $${escapeHtml(p.rating)}
                    </div>
                  </div>

                  <span class="tag">
                    <i class="fa-solid fa-box-open"></i>
                    Kit
                  </span>
                </div>

                <div class="card-actions">
                  <button class="card-btn secondary" data-action="details" data-id="$${p.id}">
                    <i class="fa-solid fa-eye"></i>
                    Details
                  </button>

                  <button class="card-btn primary" data-action="add" data-id="$${p.id}">
                    <i class="fa-solid fa-cart-plus"></i>
                    Add
                  </button>
                </div>
              </div>
            </article>
          `
        )
        .join("");
    }

    function openModal(productId) {
      const modal = byId("productModal");
      const modalBody = byId("modalBody");

      if (!modal || !modalBody) return;

      const product = getProducts().find((p) => p.id === Number(productId));
      if (!product) return;

      modalBody.innerHTML = `
        <div class="modal-grid">
          <img
            class="modal-img"
            src="$${escapeHtml(assetUrl(product.image))}"
            alt="$${escapeHtml(product.name)}"
            onerror="this.onerror=null;this.src='$${escapeHtml(product.fallback)}';"
          />

          <div class="modal-info">
            <span class="pill">
              <i class="$${escapeHtml(product.icon)}"></i>
              $${escapeHtml(product.badge)}
            </span>

            <h2>$${escapeHtml(product.name)}</h2>

            <p>$${escapeHtml(product.description)}</p>

            <div class="detail-list">
              <p><strong>Crop:</strong> $${escapeHtml(product.crop)}</p>
              <p><strong>Stage:</strong> $${escapeHtml(product.stage)}</p>
              <p><strong>Category:</strong> $${escapeHtml(product.category)}</p>
              <p><strong>Ingredients:</strong> $${escapeHtml(product.ingredients.join(", "))}</p>
              <p><strong>Rating:</strong> <i class="fa-solid fa-star" style="color:#f6a800"></i> $${escapeHtml(product.rating)}</p>
              <p><strong>Price:</strong> $${money(product.price)}</p>
            </div>

            <div class="hero-actions">
              <button class="modal-action primary" data-action="add" data-id="$${product.id}">
                <i class="fa-solid fa-cart-plus"></i>
                Add to cart
              </button>

              <button class="modal-action secondary" id="closeFromModal">
                <i class="fa-solid fa-xmark"></i>
                Close
              </button>
            </div>
          </div>
        </div>
      `;

      modal.classList.remove("hidden");
      modal.setAttribute("aria-hidden", "false");

      byId("closeFromModal")?.addEventListener("click", closeModal);

      modalBody.querySelector("[data-action='add']")?.addEventListener("click", (e) => {
        addToCart(e.currentTarget.dataset.id);
      });
    }

    function closeModal() {
      const modal = byId("productModal");

      if (modal) {
        modal.classList.add("hidden");
        modal.setAttribute("aria-hidden", "true");
      }
    }

    function addToCart(productId) {
      const product = getProducts().find((p) => p.id === Number(productId));
      if (!product) return;

      const existing = state.cart.find((item) => item.id === product.id);

      if (existing) {
        existing.qty += 1;
      } else {
        state.cart.push({
          id: product.id,
          name: product.name,
          price: product.price,
          image: product.image,
          fallback: product.fallback,
          icon: product.icon,
          crop: product.crop,
          qty: 1
        });
      }

      saveCart();
      showToast(`$${product.name} added to cart`);
    }

    function bindHomeEvents() {
      byId("searchInput")?.addEventListener("input", (e) => {
        state.search = e.target.value;
        renderProducts();
      });

      byId("filterBar")?.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-filter]");
        if (!btn) return;

        state.filter = btn.dataset.filter;

        document.querySelectorAll(".chip").forEach((chip) => {
          chip.classList.toggle("active", chip === btn);
        });

        renderProducts();
      });

      byId("productGrid")?.addEventListener("click", (e) => {
        const btn = e.target.closest("button[data-action]");
        if (!btn) return;

        if (btn.dataset.action === "details") {
          openModal(btn.dataset.id);
        }

        if (btn.dataset.action === "add") {
          addToCart(btn.dataset.id);
        }
      });

      byId("closeModal")?.addEventListener("click", closeModal);

      byId("productModal")?.addEventListener("click", (e) => {
        if (e.target.id === "productModal") {
          closeModal();
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
      });
    }

    function cartGrandTotal() {
      return state.cart.reduce((sum, item) => sum + item.price * item.qty, 0);
    }

    function renderCartPage() {
      const list = byId("cartList");
      const subtotal = byId("cartSubtotal");
      const delivery = byId("cartDelivery");
      const total = byId("cartTotal");

      if (!list) return;

      if (!state.cart.length) {
        list.innerHTML = `
          <div class="empty-state card">
            <i class="fa-solid fa-basket-shopping"></i>
            <h3>Your cart is empty</h3>
            <p>Go back to the marketplace and add crop-care products.</p>
            <div class="hero-actions" style="justify-content:center;">
              <a href="../static.html" class="form-btn primary">
                <i class="fa-solid fa-store"></i>
                Continue shopping
              </a>
            </div>
          </div>
        `;

        if (subtotal) subtotal.textContent = money(0);
        if (delivery) delivery.textContent = money(0);
        if (total) total.textContent = money(0);
        return;
      }

      list.innerHTML = state.cart
        .map(
          (item) => `
            <div class="cart-row">
              <img
                class="cart-img"
                src="$${escapeHtml(assetUrl(item.image))}"
                alt="$${escapeHtml(item.name)}"
                onerror="this.onerror=null;this.src='$${escapeHtml(item.fallback || "")}';"
              />

              <div>
                <span class="tag">
                  <i class="$${escapeHtml(item.icon || "fa-solid fa-seedling")}"></i>
                  $${escapeHtml(item.crop || "crop")}
                </span>

                <h3>$${escapeHtml(item.name)}</h3>
                <p>Unit price: $${money(item.price)}</p>
              </div>

              <div class="cart-actions">
                <strong>$${money(item.price * item.qty)}</strong>

                <div class="qty-stepper">
                  <button class="qty-btn" data-action="dec" data-id="$${item.id}">
                    <i class="fa-solid fa-minus"></i>
                  </button>

                  <strong>$${item.qty}</strong>

                  <button class="qty-btn" data-action="inc" data-id="$${item.id}">
                    <i class="fa-solid fa-plus"></i>
                  </button>
                </div>

                <button class="icon-btn danger" data-action="remove" data-id="$${item.id}">
                  <i class="fa-solid fa-trash"></i>
                </button>
              </div>
            </div>
          `
        )
        .join("");

      const grand = cartGrandTotal();
      const deliveryCharge = grand > 0 ? 49 : 0;

      if (subtotal) subtotal.textContent = money(grand);
      if (delivery) delivery.textContent = money(deliveryCharge);
      if (total) total.textContent = money(grand + deliveryCharge);
    }

    function bindCartEvents() {
      byId("cartList")?.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-action]");
        if (!btn) return;

        const id = Number(btn.dataset.id);
        const item = state.cart.find((cartItem) => cartItem.id === id);

        if (btn.dataset.action === "remove") {
          state.cart = state.cart.filter((cartItem) => cartItem.id !== id);
          showToast("Item removed from cart");
        }

        if (btn.dataset.action === "inc" && item) {
          item.qty += 1;
        }

        if (btn.dataset.action === "dec" && item) {
          item.qty -= 1;

          if (item.qty <= 0) {
            state.cart = state.cart.filter((cartItem) => cartItem.id !== id);
          }
        }

        saveCart();
        renderCartPage();
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      updateCartCount();

      const page = document.body.dataset.page || "home";

      if (page === "home") {
        renderProducts();
        bindHomeEvents();
      }

      if (page === "cart") {
        renderCartPage();
        bindCartEvents();
      }
    });

