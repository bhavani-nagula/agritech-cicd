  - path: /var/www/agritech/pages/login.html
    permissions: "0644"
    owner: root:root
    content: |
            ```html
    <!DOCTYPE html>
    <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>Login - AgriTech Marketplace</title>

      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />

      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      />

      <link rel="stylesheet" href="../css/style.css" />
    </head>

    <body class="auth-body" data-page="login">

      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark">
            <i class="fa-solid fa-seedling"></i>
          </span>
          <span>
            <strong>AgriTech Marketplace</strong>
            <small>Farmer login</small>
          </span>
        </a>

        <nav class="nav">
          <a href="/">
            <i class="fa-solid fa-house"></i> Home
          </a>

          <a href="login.html" class="active">
            <i class="fa-solid fa-right-to-bracket"></i> Login
          </a>

          <a href="register.html">
            <i class="fa-solid fa-user-plus"></i> Register
          </a>
        </nav>
      </header>

      <main class="auth-shell container">

        <section class="auth-panel">
          <span class="pill">
            <i class="fa-solid fa-lock"></i>
            Secure Login
          </span>

          <h1>Welcome back, farmer.</h1>

          <p>
            Continue managing crop preferences, cart items and recommendations.
          </p>

          <div class="auth-benefits">
            <span><i class="fa-solid fa-circle-check"></i> Save product preferences</span>
            <span><i class="fa-solid fa-circle-check"></i> Track cart items</span>
            <span><i class="fa-solid fa-circle-check"></i> Continue crop recommendations</span>
          </div>
        </section>

        <form class="form-card" id="loginForm">

          <h1>Login</h1>
          <p>Enter your email and password to continue.</p>

          <div class="form-grid">

            <label>Email address</label>
            <div class="input-wrap">
              <i class="fa-solid fa-envelope"></i>
              <input
                type="email"
                id="email"
                placeholder="farmer@example.com"
                required
              />
            </div>

            <label>Password</label>
            <div class="input-wrap">
              <i class="fa-solid fa-lock"></i>
              <input
                type="password"
                id="password"
                placeholder="Your password"
                required
              />
            </div>

          </div>

          <div class="hero-actions">

            <button class="form-btn primary" type="submit">
              <i class="fa-solid fa-right-to-bracket"></i>
              Sign In
            </button>

            <a class="form-btn secondary" href="/">
              <i class="fa-solid fa-arrow-left"></i>
              Back Home
            </a>

          </div>

        </form>

      </main>

    <script>

    document.getElementById("loginForm").addEventListener("submit", async function(e){

        e.preventDefault();

        const email = document.getElementById("email").value;
        const password = document.getElementById("password").value;

        try {

            const response = await fetch(
                "http://13.71.2.44:8080/api/login",
                {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        username: email,
                        password: password
                    })
                }
            );

            const result = await response.text();

            alert(result);

        } catch(error) {

            console.error(error);
            alert("Failed to connect to backend");

        }

    });

    </script>

    </body>
    </html>
    ```

  - path: /var/www/agritech/pages/register.html
    permissions: "0644"
    owner: root:root
    content: |
            <!DOCTYPE html>
    <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>Register - AgriTech Marketplace</title>

      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />

      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      />

      <link rel="stylesheet" href="../css/style.css" />
    </head>

    <body class="auth-body" data-page="register">

      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark">
            <i class="fa-solid fa-seedling"></i>
          </span>
          <span>
            <strong>AgriTech Marketplace</strong>
            <small>Create farmer account</small>
          </span>
        </a>

        <nav class="nav">
          <a href="/">
            <i class="fa-solid fa-house"></i> Home
          </a>

          <a href="login.html">
            <i class="fa-solid fa-right-to-bracket"></i> Login
          </a>

          <a href="register.html" class="active">
            <i class="fa-solid fa-user-plus"></i> Register
          </a>
        </nav>
      </header>

      <main class="auth-shell container">

        <section class="auth-panel">
          <span class="pill">
            <i class="fa-solid fa-user-plus"></i>
            New Farmer Account
          </span>

          <h1>Start your smart farming journey.</h1>

          <p>
            Register to save crops, cart items, recommendations and future order
            history when backend APIs are connected.
          </p>

          <div class="auth-benefits">
            <span>
              <i class="fa-solid fa-circle-check"></i>
              Personalized crop choices
            </span>

            <span>
              <i class="fa-solid fa-circle-check"></i>
              Save recommendations
            </span>

            <span>
              <i class="fa-solid fa-circle-check"></i>
              Ready for Spring Boot APIs
            </span>
          </div>
        </section>

        <form class="form-card" id="registerForm">

          <h1>Create account</h1>

          <p>
            Register to save your crops, cart and preferences.
          </p>

          <div class="form-grid">

            <label>Full Name</label>
            <div class="input-wrap">
              <i class="fa-solid fa-user"></i>
              <input
                type="text"
                id="fullname"
                placeholder="Your name"
                required
              />
            </div>

            <label>Email Address</label>
            <div class="input-wrap">
              <i class="fa-solid fa-envelope"></i>
              <input
                type="email"
                id="email"
                placeholder="farmer@example.com"
                required
              />
            </div>

            <label>Password</label>
            <div class="input-wrap">
              <i class="fa-solid fa-lock"></i>
              <input
                type="password"
                id="password"
                placeholder="Create password"
                required
              />
            </div>

            <label>Confirm Password</label>
            <div class="input-wrap">
              <i class="fa-solid fa-shield-halved"></i>
              <input
                type="password"
                id="confirmPassword"
                placeholder="Repeat password"
                required
              />
            </div>

          </div>

          <div class="hero-actions">

            <button class="form-btn primary" type="submit">
              <i class="fa-solid fa-user-plus"></i>
              Create Account
            </button>

            <a class="form-btn secondary" href="/">
              <i class="fa-solid fa-arrow-left"></i>
              Back Home
            </a>

          </div>

        </form>

      </main>

      <script>

        document.getElementById("registerForm")
          .addEventListener("submit", async function (e) {

          e.preventDefault();

          const fullName =
            document.getElementById("fullname").value;

          const email =
            document.getElementById("email").value;

          const password =
            document.getElementById("password").value;

          const confirmPassword =
            document.getElementById("confirmPassword").value;

          if (password !== confirmPassword) {
            alert("Passwords do not match");
            return;
          }

          try {

            const response = await fetch(
              "http://13.71.2.44:8080/api/register",
              {
                method: "POST",
                headers: {
                  "Content-Type": "application/json"
                },
                body: JSON.stringify({
                  username: email,
                  password: password
                })
              }
            );

            const result = await response.text();

            alert(result);

            if (response.ok) {
              window.location.href = "login.html";
            }

          } catch (error) {

            console.error(error);

            alert("Failed to connect to backend");

          }

        });

      </script>

    </body>
    </html>

  - path: /var/www/agritech/pages/cart.html
    permissions: "0644"
    owner: root:root
    content: |
            <!DOCTYPE html>
    <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>Cart - AgriTech Marketplace</title>

      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />

      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      />

      <link rel="stylesheet" href="../css/style.css" />
    </head>

    <body data-page="cart">
      <header class="topbar">
        <a class="brand" href="../static.html">
          <span class="brand-mark">
            <i class="fa-solid fa-seedling"></i>
          </span>
          <span>
            <strong>AgriTech Marketplace</strong>
            <small>Cart summary</small>
          </span>
        </a>

        <nav class="nav">
          <a href="../static.html">
            <i class="fa-solid fa-house"></i> Home
          </a>
          <a href="login.html">
            <i class="fa-solid fa-right-to-bracket"></i> Login
          </a>
          <a href="register.html">
            <i class="fa-solid fa-user-plus"></i> Register
          </a>
          <a href="cart.html" class="active cart-link">
            <i class="fa-solid fa-basket-shopping"></i>
            Cart
            <span id="cartCount">0</span>
          </a>
        </nav>
      </header>

      <main class="cart-page container">
        <div class="section-head simple">
          <div>
            <span class="pill soft">
              <i class="fa-solid fa-basket-shopping"></i>
              Shopping Cart
            </span>
            <h2>Your selected crop-care products</h2>
            <p>Increase, decrease or remove products from your cart.</p>
          </div>
        </div>

        <section class="cart-layout">
          <div class="cart-list" id="cartList"></div>

          <aside class="checkout-card">
            <span class="pill">
              <i class="fa-solid fa-receipt"></i>
              Order Summary
            </span>

            <div class="checkout-line">
              <span>Subtotal</span>
              <strong id="cartSubtotal">₹0</strong>
            </div>

            <div class="checkout-line">
              <span>Delivery</span>
              <strong id="cartDelivery">₹0</strong>
            </div>

            <div class="checkout-line total">
              <span>Total</span>
              <strong id="cartTotal">₹0</strong>
            </div>

            <div class="hero-actions">
              <a href="../static.html" class="form-btn secondary">
                <i class="fa-solid fa-store"></i>
                Continue shopping
              </a>

              <button
                class="form-btn primary"
                onclick="alert('Checkout demo only')"
              >
                <i class="fa-solid fa-credit-card"></i>
                Checkout
              </button>
            </div>
          </aside>
        </section>
      </main>

      <script src="../js/data.js"></script>
      <script src="../js/app.js"></script>
    </body>
    </html>

  - path: /etc/nginx/sites-available/agritech
    permissions: "0644"
    owner: root:root
    content: |
      server {
        listen 80 default_server;
        listen [::]:80 default_server;
        root /var/www/agritech;
        index static.html index.html;
        server_name _;
        location / {
          try_files $uri $uri/ /static.html;
        }
      }

runcmd:
  - mkdir -p /var/www/agritech/css /var/www/agritech/js /var/www/agritech/pages
  - ln -sf /etc/nginx/sites-available/agritech /etc/nginx/sites-enabled/default
  - systemctl enable nginx
  - systemctl restart nginx
